{
  "name": "@local-memory/indexer",
  "version": "0.1.4",
  "private": true,
  "description": "Write-only producer MCP server: discovers, chunks, and embeds project files into LanceDB (Spec 08.1)",
  "type": "module",
  "bin": {
    "server-local-memory-indexer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "latest",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.10.0",
    "ignore": "^7.0.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/uuid": "latest",
    "vitest": "4.1.8"
  }
}
