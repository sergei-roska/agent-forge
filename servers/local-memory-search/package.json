{
  "name": "@agent-forge/server-local-memory-search",
  "version": "1.0.0",
  "private": true,
  "description": "Read-only consumer MCP server: hybrid semantic + keyword search, context packs, and health diagnostics over the shared LanceDB index (Spec 08.2)",
  "type": "module",
  "bin": {
    "server-local-memory-search": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "latest",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.10.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "2.1.9"
  }
}
