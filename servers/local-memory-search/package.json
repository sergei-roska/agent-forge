{
  "name": "@local-memory/search",
  "version": "1.0.11",
  "private": true,
  "description": "Read-only consumer MCP server: hybrid semantic + keyword search, context packs, and health diagnostics over the shared LanceDB index (Spec 08.2)",
  "type": "module",
  "bin": {
    "search": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "latest",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.10.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "typescript": "^6.0.3",
    "vitest": "4.1.8"
  }
}
